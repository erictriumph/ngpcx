{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist-scrapers",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "types": ["node"]
  },
  "include": [
    "scrapers/**/*.ts",
    "scanner/**/*.ts"
  ]
}
